APP_ENV=production
AUTH_MODE=oidc
LOCAL_AUTH_ENABLED=false
SECRETS_INJECTED_BY_PLATFORM=true
OIDC_ISSUER=https://identity.example.com/
OIDC_AUDIENCE=rank-rent-production
OIDC_JWKS_URL=https://identity.example.com/.well-known/jwks.json
OIDC_ALLOWED_JWKS_HOSTS=["identity.example.com"]
DATABASE_URL=postgresql+psycopg://runtime@production-db.internal:5432/rank_rent
BLOB_STORE_BACKEND=s3
BLOB_STORE_S3_BUCKET=required-production-bucket
BLOB_STORE_S3_PREFIX=raw-responses
BLOB_STORE_S3_REGION=us-east-1
BLOB_STORE_S3_SERVER_SIDE_ENCRYPTION=aws:kms
DATA_MODE=fixture
ALLOW_LIVE_API_CALLS=false
ALLOW_PRODUCTION_DATAFORSEO=false
PAID_CALL_KILL_SWITCH=true
DATAFORSEO_ENVIRONMENT=production
MAX_SCAN_COST_USD=10
RATE_LIMIT_BACKEND=redis
REDIS_URL=rediss://resolved-by-platform-at-runtime
CORS_ALLOWED_ORIGINS=["https://console.example.com"]
DATAFORSEO_PASSWORD=resolved-by-platform-at-runtime
RELEASE_GIT_SHA=required-at-deploy
RELEASE_IMAGE_DIGEST=required-at-deploy
RELEASE_FRONTEND_IMAGE_DIGEST=required-at-deploy
